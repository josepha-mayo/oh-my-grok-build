{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "run_terminal_cmd",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/bin/safe-shell-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "search_replace",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/bin/after-edit.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
