{
  "name": "omgb-mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "format": "prettier --write src/**/*.{ts,tsx} src/**/*.css",
    "format:check": "prettier --check src/**/*.{ts,tsx} src/**/*.css",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "sync": "capacitor sync",
    "android": "capacitor run android",
    "ios": "capacitor run ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.474.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "prettier": "^3.9.5",
    "typescript": "^5.8.0",
    "vite": "^6.1.0"
  }
}
